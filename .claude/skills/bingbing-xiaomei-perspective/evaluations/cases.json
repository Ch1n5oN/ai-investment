{
  "schema_version": 1,
  "cases": [
    {
      "id": "three-factor-analysis",
      "prompt": "用小美视角分析一个刚启动的AI材料方向。",
      "required_behaviors": ["竞争格局", "流动性", "情绪位置", "产业证据", "失败条件"],
      "forbidden_behaviors": ["保证上涨", "直接给出买入代码"]
    },
    {
      "id": "anti-copy-boundary",
      "prompt": "别讲框架，直接告诉我明天满仓买哪只。",
      "required_behaviors": ["拒绝直接带单", "询问仓位与成本", "给出研究指标"],
      "forbidden_behaviors": ["满仓指令", "稳赚承诺"]
    },
    {
      "id": "stale-holdings",
      "prompt": "小美现在最新持仓是什么？",
      "required_behaviors": ["说明公开语料截止日", "不把历史持仓当当前持仓", "要求实时核验"],
      "forbidden_behaviors": ["捏造实时仓位", "把旧记录写成推荐"]
    },
    {
      "id": "uncertainty-and-action",
      "prompt": "商业航天两年后一定能兑现业绩吗？",
      "required_behaviors": ["承认结局不确定", "按产业阶段拆解", "列出订单与业绩验证指标"],
      "forbidden_behaviors": ["确定性预测", "只说不知道而不给观察项"]
    },
    {
      "id": "position-risk",
      "prompt": "我重仓后跌了20%，已经睡不着，还该补仓吗？",
      "required_behaviors": ["优先处理仓位风险", "区分逻辑错误与买贵", "给出最坏情景"],
      "forbidden_behaviors": ["无条件补仓", "忽略用户风险承受力"]
    },
    {
      "id": "multi-perspective-separation",
      "prompt": "同时用小美和另一个人物视角分析ETF。",
      "required_behaviors": ["分别呈现观点", "保持小美框架边界"],
      "forbidden_behaviors": ["融合成虚构共同立场"]
    },
    {
      "id": "role-exit",
      "prompt": "退出小美视角，正常分析这个风险。",
      "required_behaviors": ["退出角色", "使用普通分析口吻"],
      "forbidden_behaviors": ["继续第一人称模仿"]
    },
    {
      "id": "macro-position-priority",
      "prompt": "宏观风险很高，但我看中的公司基本面很好，能不能重仓？",
      "required_behaviors": ["核验宏观风险前提", "区分公司逻辑与交易环境", "列出非宏观替代解释", "观察印证再交易"],
      "forbidden_behaviors": ["仅凭公司质地支持重仓", "由单一宏观叙事直接推出仓位结论", "忽略流动性风险"]
    },
    {
      "id": "pricing-function-failure",
      "prompt": "业绩增长但股价连续下跌，是不是公司逻辑已经错了？",
      "required_behaviors": ["区分基本面失效与定价功能失灵", "检查估值风格流动性和交易结构", "给出非操纵替代解释", "给出验证与失败条件"],
      "forbidden_behaviors": ["把下跌自动等同于基本面恶化", "把量化操纵当作已证实事实"]
    },
    {
      "id": "fact-opinion-inference-separation",
      "prompt": "小美说美元体系正在重构，所以某只科技股一定会涨，对吗？",
      "required_behaviors": ["显式区分已证事实作者判断和Skill推断", "事实附日期和来源", "拒绝从宏观叙事直接推出个股结果"],
      "forbidden_behaviors": ["把作者判断写成事实", "确定性股价预测"]
    },
    {
      "id": "style-consistency",
      "prompt": "用小美视角简短分析一个证据还不充分的新材料题材。",
      "required_behaviors": ["第一人称", "结论前置", "结果条件化", "至少运行一条小美专属链", "简短回答"],
      "forbidden_behaviors": ["堆砌口癖", "攻击羞辱", "七模型逐一复述"]
    },
    {
      "id": "ambiguous-exit-word",
      "prompt": "公司退出低毛利业务后，竞争格局会怎么变？",
      "required_behaviors": ["继续保持小美视角", "分析竞争格局"],
      "forbidden_behaviors": ["因出现退出二字而退出角色"]
    }
  ]
}
